{
  "name": "threadsmith",
  "private": true,
  "version": "0.3.2",
  "description": "Workflow-first control deck for supervising AI coding projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teddy-creator/Threadsmith-control-deck.git"
  },
  "homepage": "https://github.com/Teddy-creator/Threadsmith-control-deck#readme",
  "bugs": {
    "url": "https://github.com/Teddy-creator/Threadsmith-control-deck/issues"
  },
  "keywords": [
    "ai-coding",
    "workflow",
    "control-deck",
    "codex",
    "threadsmith"
  ],
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node scripts/start-message.mjs && npm run dev --workspace @threadsmith/control-deck -- --host 127.0.0.1 --port 5173",
    "dev": "npm run dev --workspace @threadsmith/control-deck",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "threadsmith:autopilot": "node --import tsx scripts/threadsmith-autopilot.ts",
    "threadsmith:bridge-refresh": "node --import tsx scripts/threadsmith-bridge-refresh.ts",
    "threadsmith:adapters": "node --import tsx scripts/threadsmith-adapters.ts",
    "threadsmith:handoff": "node --import tsx scripts/threadsmith-handoff.ts",
    "threadsmith:proposal-status": "node --import tsx scripts/threadsmith-proposal-status.ts",
    "threadsmith:review-proposal": "node --import tsx scripts/threadsmith-review-proposal.ts",
    "threadsmith:adopt-proposal": "node --import tsx scripts/threadsmith-adopt-proposal.ts",
    "threadsmith:phase-history:candidates": "node --import tsx scripts/threadsmith-phase-history-candidates.ts",
    "threadsmith:phase-history:backfill": "node --import tsx scripts/threadsmith-phase-history-backfill.ts",
    "threadsmith:phase-history:summary": "node --import tsx scripts/threadsmith-phase-history-summary.ts",
    "test:e2e": "playwright test",
    "test:e2e:autopilot": "playwright test tests/e2e/autopilot-v1.spec.ts",
    "test:e2e:bridge": "playwright test tests/e2e/agent-run-bridge.spec.ts",
    "verify:launchers:macos": "node scripts/verify-macos-launchers.mjs",
    "verify:launchers:windows": "node scripts/verify-powershell-launchers.mjs",
    "verify:launchers": "npm run verify:launchers:macos && npm run verify:launchers:windows",
    "verify:project-truth": "node --import tsx scripts/verify-project-truth.mjs",
    "verify:skill-sync": "node scripts/verify-threadsmith-skill-sync.mjs",
    "verify:skill-contract": "node scripts/verify-threadsmith-skill-contract.mjs",
    "verify:autopilot": "npm run test --workspace @threadsmith/orchestrator && npm run test --workspace @threadsmith/runtime && npm run test --workspace @threadsmith/control-deck -- src/test/renderDeck.workflow.test.tsx && npm run test:e2e:autopilot && npm run smoke:autopilot",
    "verify:release": "npm run test && npm run build && npm run test:e2e && npm run smoke:autopilot && npm run verify:launchers",
    "verify:bridge": "npm run test --workspace @threadsmith/orchestrator && npm run test:e2e:bridge",
    "smoke:self-host": "node --import tsx scripts/self-host-smoke.ts",
    "smoke:autopilot": "node --import tsx scripts/threadsmith-autopilot-smoke.ts",
    "smoke:state-bridge": "node --import tsx scripts/cross-agent-state-bridge-smoke.ts",
    "smoke:review-proposal": "node --import tsx scripts/threadsmith-review-proposal-smoke.ts",
    "smoke:bridge-refresh": "node --import tsx scripts/threadsmith-bridge-refresh-smoke.ts",
    "smoke:proposal-status": "node --import tsx scripts/threadsmith-proposal-status-smoke.ts",
    "smoke:proposal-roundtrip": "node --import tsx scripts/threadsmith-proposal-roundtrip-smoke.ts",
    "smoke:proposal-fixtures": "node --import tsx scripts/threadsmith-proposal-fixtures-smoke.ts",
    "smoke:deck-route": "node --import tsx scripts/deck-route-smoke.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "tsx": "^4.8.1"
  }
}
